{
  "name": "ozgur-sohbet",
  "version": "1.0.0",
  "description": "Özgür Sohbet - P2P Masaüstü İletişim Uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dev2": "electron . --profile=2",
    "web": "node server.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "express": "^5.2.1"
  },
  "build": {
    "appId": "com.alchemei.alcord",
    "productName": "ALCORD",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ALCORD"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png"
    },
    "dmg": {
      "title": "ALCORD",
      "icon": "icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "**/*",
      "!ALCORD-win32-x64/**/*",
      "!dist/**/*"
    ]
  }
}
